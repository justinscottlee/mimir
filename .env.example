# =============================================================================
#  Mimir — environment configuration
# =============================================================================
#  Copy this file before running:
#    • Docker:  cp .env.example .env        (docker compose reads .env)
#
#  Everything except BETTER_AUTH_SECRET has a working default. The values below
#  are tuned for a fully-featured local instance: the execution sandbox and web
#  search are enabled, and the limits are sensible starting points. Read the
#  comments before loosening anything security-related.
# =============================================================================


# --- Database (PostgreSQL) ---------------------------------------------------
# Connection string used by Drizzle and Better Auth. In docker compose this is
# overridden to the internal "postgres" service, so this localhost value is what
# you want when running the app directly on your host (Option B).
DATABASE_URL=postgres://mimir:mimir@localhost:5432/mimir


# --- Cache / secondary storage (Valkey, Redis-compatible) --------------------
# Application snapshot cache + Better Auth session storage. Overridden to the
# internal "valkey" service under docker compose.
VALKEY_URL=redis://localhost:6379


# --- Better Auth -------------------------------------------------------------
# REQUIRED. The signing secret for every session — anyone who knows it can forge
# logins. Generate your own unique value and never reuse the placeholder below:
#   openssl rand -base64 32
# (Non-empty so the app boots for a quick local try, but CHANGE IT before any
# real use, and do not commit a real secret.)
BETTER_AUTH_SECRET=CHANGE_ME

# Public base URL of the app (used for cookies and callbacks).
BETTER_AUTH_URL=http://localhost:3000

# "true" allows new sign-ups. Flip to "false" once you've created your own
# account to lock the instance down (existing accounts can still sign in).
ALLOW_SIGNUP=true


# --- Web search (SearXNG) ----------------------------------------------------
# Server-side URL of the SearXNG instance used by the web_search tool. When set,
# it takes precedence over the per-user URL in the Tools window, so search works
# with no extra setup. This localhost value is the bundled SearXNG's published
# port; under docker compose it is overridden to the internal service
# (http://searxng:8080), so web search works in BOTH modes out of the box.
# Point it at an external SearXNG to use one instead.
#
# Note: the web_search / web_fetch tools still ship toggled OFF in the Tools
# window (a deliberate, visible choice, since they let a query leave the
# machine). Turn them on there to actually offer them to the model.
SEARXNG_URL=http://localhost:8888


# --- Workspace execution sandbox (Docker) ------------------------------------
# Workspaces run shell commands and scripts inside a per-workspace Docker
# container so an agent can actually run, test, and fix the code it writes.
#
# ⚠️  THIS EXECUTES MODEL-WRITTEN CODE ON YOUR HOST. The container is hardened
#     (dropped capabilities, no-new-privileges, resource + time limits) but the
#     isolation is best-effort, not a guarantee. Requires a reachable Docker
#     daemon — if Mimir itself runs in Docker (Option A), the host socket is
#     mounted for you (see DOCKER_SOCK).
#
# Master switch (set to "false" to turn the whole feature off):
SANDBOX_ENABLED=true

# Image commands run in. The default has Python 3 + a POSIX shell. Point this at
# a richer image for more languages/toolchains (it only needs coreutils
# `timeout` and `sh`), e.g. one with gcc, Node, Go, Rust, etc.
SANDBOX_IMAGE=python:3.12-slim

# Network for executed code:
#   none   = no internet (the hardened option; `pip install` / `npm install` fail)
#   bridge = normal outbound network (lets the agent install packages)
# Shipped as "bridge" so package installs and dependency-using code work out of
# the box. This widens the attack surface of code the model runs — switch to
# "none" if you don't need installs and want the tighter sandbox.
SANDBOX_NETWORK=bridge

# Resource and safety limits per container:
SANDBOX_MEMORY_MB=512        # memory cap (MB)
SANDBOX_CPUS=1               # CPU cap (cores; fractional allowed, e.g. 0.5)
SANDBOX_PIDS=256             # max processes
SANDBOX_TIMEOUT_MS=30000     # per-command wall-clock limit (ms)
SANDBOX_IDLE_MS=600000       # stop a container after this much idle time (ms)

# Extra hardening (optional). READONLY_ROOT hardens further but breaks system
# pip; SANDBOX_USER runs as a specific uid:gid instead of the image default.
# SANDBOX_READONLY_ROOT=false
# SANDBOX_USER=1000:1000

# Filesystem sync caps — what gets mirrored from the container back into the
# editor after a command. Keeps the store sane when a command writes a lot.
SANDBOX_MAX_FILE_KB=256      # skip files larger than this
SANDBOX_MAX_FILES=2000       # cap on number of files synced back
SANDBOX_MAX_TOTAL_MB=12      # cap on total bytes synced back
SANDBOX_MAX_OUTPUT_KB=256    # cap on captured stdout/stderr per command


# --- Docker socket / daemon --------------------------------------------------
# COMPOSE ONLY: the host Docker socket handed to the Mimir container.
# Defaults to /var/run/docker.sock, which is correct on Linux and most Docker
# Desktop setups. Uncomment and set only if yours lives elsewhere — common on
# macOS Docker Desktop, Colima, or rootless Docker. Find it with
# `docker context ls` (the endpoint of the active context), e.g.:
DOCKER_SOCK=/var/run/docker.sock
